# Code-only: R scripts, 00_functions.R and methodology docs (*.md) are tracked;
# curated data, evidence, reviews, results and backups are not.

# Curated data, evidence and results
input/
results/
backups/
reviews/

# agent/: track methodology (skills, tools, README);
# curated dossiers under workspace/ stay local-only.
agent/workspace/**
!agent/workspace/**/
!agent/workspace/**/.gitkeep

# dual_curation_validation: keep scripts + docs, drop its data and results
dual_curation_validation/input/
dual_curation_validation/results/

# Language / editor noise
.Rhistory
.RData
*.log
